# ── LLM (OpenAI-compatible) ───────────────────────────────────────────────────
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_API_KEY=sk-xxx
# MODEL_NAME=qwen-plus-latest

# ── Embedding (API mode) ─────────────────────────────────────────────────────
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_MODEL_NAME=text-embedding-v4

# ── Reranker (API mode) ──────────────────────────────────────────────────────
# RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# RERANK_API_KEY=sk-xxx
# RERANK_MODEL=gte-rerank-v2

# ── Embedding model (local path, absolute) ───────────────────────────────────
# EMBEDDING_MODEL=/root/.cache/huggingface/hub/models--BAAI--bge-m3/snapshots/<hash>

# ── Reranker model (local path, absolute) ────────────────────────────────────
# RERANKER_MODEL=/root/.cache/huggingface/hub/models--BAAI--bge-reranker-v2-m3/snapshots/<hash>

# ── Optional: force offline mode (auto-enabled when using local paths) ───────
# EMBEDDING_LOCAL_FILES_ONLY=true
# RERANKER_LOCAL_FILES_ONLY=true

# ── HanLP (Chinese NLP tokenizer) ────────────────────────────────────────────
# HANLP_HOME=/workspace/hanlp
# HANLP_TOKENIZER_PATH=/workspace/hanlp/tok/coarse_electra_small_20220616_012050/coarse_electra_small_20220616_012050

# ── Langfuse observability / tracing ─────────────────────────────────────────
# Enable Langfuse to get per-request traces, latency, token usage and cost
# in the Langfuse dashboard.  Self-host: https://langfuse.com/docs/deployment/self-host
# Install: uv sync --extra observability
#
# ENABLE_LANGFUSE=true
# LANGFUSE_PUBLIC_KEY=pk-lf-xxx
# LANGFUSE_SECRET_KEY=sk-lf-xxx
# LANGFUSE_HOST=http://localhost:3000          # Self-hosted Langfuse URL
# LANGFUSE_RELEASE=                            # Optional version tag for traces
# LANGFUSE_DEBUG=false                         # Verbose SDK logging

# ── RAGAS evaluation metrics ─────────────────────────────────────────────────
# Computes answer-quality scores (faithfulness, relevancy, context precision)
# and pushes them into Langfuse traces when both systems are enabled.
# Install: uv sync --extra observability
#
# ENABLE_RAGAS=true
# RAGAS_SAMPLE_RATE=1.0                        # Fraction of requests to evaluate (0.0–1.0)
# RAGAS_METRICS=["faithfulness","response_relevancy","context_precision"]
# RAGAS_EVAL_LLM_MODEL=                        # Defaults to OPENAI_MODEL if unset
# RAGAS_EVAL_LLM_API_BASE=                     # Defaults to OPENAI_BASE_URL if unset
# RAGAS_EVAL_LLM_API_KEY=                      # Defaults to OPENAI_API_KEY if unset
